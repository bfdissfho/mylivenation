// @grant        none
// ==/UserScript==

(function() {
    'use strict';

    const buttonId = 'buyTicketBtn';
    let isWaiting = false; // 增加一個狀態鎖，防止重複觸發

    function checkButton() {
        const button = document.getElementById(buttonId);

        // 如果找到按鈕，且目前沒有在等待延遲中
        if (button && !isWaiting) {
            isWaiting = true; // 鎖定狀態
            console.log('找到按鈕！將在 2 秒後執行點擊...');

            // 停止每秒檢查的計時器
            clearInterval(aa);

            // 延遲 2000 毫秒 (2秒) 執行點擊
            setTimeout(function() {
                button.click();
                console.log('已執行點擊');
            }, 2000);

        } else if (!button) {
            console.log('尚未發現按鈕，持續監測中...');
        }
    }

    // 每 1000 毫秒 (1秒) 檢查一次
    const aa = setInterval(checkButton, 1000);
})();
